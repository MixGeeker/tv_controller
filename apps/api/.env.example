# API 监听地址。
# 作用：决定 NestJS 服务绑定到哪个网卡地址。
# 为什么默认写 0.0.0.0：这样不仅本机能访问，局域网内其他机器和电视也能访问到它。
HOST=0.0.0.0

# API 监听端口。
# 作用：决定后端 REST API 和媒体静态服务使用的端口。
# 为什么默认写 3100：和前端开发端口分开，避免常见冲突，也便于记忆。
PORT=3100

# 上传文件目录。
# 作用：本地上传的 mp4、jpg、png 等文件会保存到这里。
# 为什么推荐写 uploads：该值会按 apps/api 目录解析，最终落到 apps/api/uploads，开发和部署都比较直观。
UPLOADS_DIR=uploads

# 可选：指定 SSDP 设备发现时使用的网卡名称。
# 作用：当机器上存在多张网卡时，只在指定网卡上发送和接收 SSDP 发现报文。
# 为什么这个参数有价值：像 ZeroTier、WSL、虚拟交换机、蓝牙网卡都会干扰 SSDP，多网卡环境下不指定时经常出现“手机能扫到、电脑程序扫不到”的情况。
# 典型示例：Windows 中文系统常见是 以太网 或 WLAN。
NETWORK_INTERFACE=以太网

# 电视访问媒体时使用的公开地址。
# 作用：后端会基于这个地址拼接媒体文件 URL，例如 http://你的IP:3100/files/xxx.mp4。
# 为什么必须写局域网 IP：电视不会去访问 localhost，它只会访问自己所在局域网中真正能连到的地址。
# 错误示例：http://localhost:3100
# 正确示例：http://192.168.124.19:3100
PUBLIC_BASE_URL=http://192.168.124.19:3100
